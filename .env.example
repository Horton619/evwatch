# evwatch environment variables
# Copy to .env (gitignored) and fill in. See SPEC §7 for full setup.

# --- Supabase (shared with the existing Flux project) ---
# URL of the Flux Supabase project. Same value used by GHA, Vercel, and the
# Electron app.
SUPABASE_URL=

# Service-role key — write access; bypasses RLS. GHA + ad-hoc Mac runs only.
# NEVER ship this to the browser or the Electron renderer.
SUPABASE_SERVICE_ROLE_KEY=

# Anon key — read-only access via RLS policies. Used by Vercel (server-side
# env, NOT NEXT_PUBLIC_) and baked into the Electron build for read queries.
SUPABASE_ANON_KEY=

# --- Email (shared with Flux/Calltime Resend account) ---
RESEND_API_KEY=

# --- eBay Browse API ---
# Get both from https://developer.ebay.com — free tier is 5000 calls/day.
# Browse API uses OAuth2 client-credentials, which requires BOTH the App ID
# (client id) and Cert ID (client secret).
EBAY_APP_ID=
EBAY_CERT_ID=

# --- Email digest routing ---
# Resend sender address. Must be on a domain verified in your Resend account
# (the Flux/Calltime stack uses veproductions.net).
EVWATCH_DIGEST_FROM=noreply@veproductions.net
# Single recipient for v1 (multi-recipient is out of scope per SPEC §3).
EVWATCH_DIGEST_TO=dave@veproductions.net

# --- Dashboard URL ---
# Used in email footers. Override once the Vercel deployment is up.
EVWATCH_DASHBOARD_URL=https://evwatch.veproductions.net

# --- Wayback Machine (optional, phase 7) ---
# Set for higher rate limits when running the historical seeder from the Mac.
# Leave blank to use anonymous archive.org access.
ARCHIVE_ORG_USER=
