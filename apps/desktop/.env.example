# evwatch desktop env vars
# Copy to apps/desktop/.env (gitignored) for local dev.
# CI release builds inject these via the GitHub Actions workflow env.
#
# Per SPEC §7 point 11: the anon key is baked into the renderer bundle.
# RLS enforces read-only — service-role-only writes happen in GHA/Mac
# subprocesses.
#
# Vite requires the VITE_ prefix to surface these to the renderer.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
