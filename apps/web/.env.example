# evwatch dashboard env vars
# Copy to apps/web/.env.local (gitignored) for local dev.
# On Vercel, set these as regular env vars (NOT NEXT_PUBLIC_).
#
# The anon key is read-only via RLS. It never reaches the browser —
# all queries happen server-side in Server Components (SPEC §5.6).

SUPABASE_URL=
SUPABASE_ANON_KEY=
