{% macro render_card(item, kind='priority') -%}
<table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;border-collapse:collapse;background:#10141f;border:1px solid rgba(237,237,237,0.08);border-radius:8px;margin-bottom:12px;">
  <tr>
    <td style="width:120px;padding:12px;vertical-align:top;">
      {% if item.thumbnail_url %}
      <img src="{{ item.thumbnail_url }}" alt="" width="120" style="display:block;border-radius:4px;" />
      {% endif %}
    </td>
    <td style="padding:12px 12px 12px 0;vertical-align:top;">
      <div style="font-size:16px;font-weight:600;color:#ededed;">
        {{ item.year or '----' }} {{ item.make }} {{ item.model }}{% if item.trim %} {{ item.trim }}{% endif %}
      </div>
      <div style="font-size:20px;font-weight:600;color:#f97316;margin-top:4px;">
        {% if item.price %}${{ '{:,}'.format(item.price) }}{% else %}—{% endif %}
      </div>

      {# Below-market delta — orange-ish #}
      {% if kind == 'deal' and item._below_market %}
      <div style="font-size:12px;color:#10b981;margin-top:4px;">
        ${{ '{:,}'.format(item._below_market.dollars_below) }} below market
        ({{ (item._below_market.pct_below * 100) | round(1) }}% under
        ${{ '{:,}'.format(item._below_market.baseline_median) }} median,
        {{ item._below_market.comp_count }} comps)
      </div>
      {% endif %}

      {# Price drop delta — cyan-ish #}
      {% if kind == 'drop' and item._price_drop %}
      <div style="font-size:12px;color:#22d3ee;margin-top:4px;">
        ${{ '{:,}'.format(item._price_drop.delta | abs) }}
        ({{ (item._price_drop.delta_pct * 100) | round(1) }}%) from
        ${{ '{:,}'.format(item._price_drop.previous_price) }}
      </div>
      {% endif %}

      <div style="font-size:13px;color:rgba(237,237,237,0.6);margin-top:6px;">
        {% if item.mileage %}{{ '{:,}'.format(item.mileage) }} mi{% else %}mileage unknown{% endif %}
        {% if item.miles_from_port_orchard is not none %} · {{ item.miles_from_port_orchard }} mi away{% endif %}
        · {{ item.source }}
      </div>
      <div style="margin-top:10px;">
        <a href="{{ item.url }}" style="color:#f97316;text-decoration:none;font-size:13px;">View listing →</a>
      </div>
    </td>
  </tr>
</table>
{%- endmacro %}
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{{ subject }}</title>
  </head>
  <body style="margin:0;padding:24px;background:#070910;color:#ededed;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
    <div style="max-width:680px;margin:0 auto;">
      <p style="font-size:11px;letter-spacing:0.3em;text-transform:uppercase;color:rgba(237,237,237,0.5);margin:0 0 8px 0;">
        evwatch · {{ today }}
      </p>
      <h1 style="font-size:24px;font-weight:600;margin:0 0 24px 0;color:#ededed;">
        {{ heading }}
      </h1>

      {% if priority %}
      <h2 style="font-size:14px;letter-spacing:0.15em;text-transform:uppercase;color:#f97316;margin:32px 0 12px 0;">
        Priority watchlist ({{ priority|length }})
      </h2>
      {% for item in priority %}
        {{ render_card(item, kind='priority') }}
      {% endfor %}
      {% endif %}

      {% if deals %}
      <h2 style="font-size:14px;letter-spacing:0.15em;text-transform:uppercase;color:#10b981;margin:32px 0 12px 0;">
        Below market ({{ deals|length }})
      </h2>
      {% for item in deals %}
        {{ render_card(item, kind='deal') }}
      {% endfor %}
      {% endif %}

      {% if drops %}
      <h2 style="font-size:14px;letter-spacing:0.15em;text-transform:uppercase;color:#22d3ee;margin:32px 0 12px 0;">
        Price drops ({{ drops|length }})
      </h2>
      {% for item in drops %}
        {{ render_card(item, kind='drop') }}
      {% endfor %}
      {% endif %}

      <p style="margin:48px 0 0 0;font-size:12px;color:rgba(237,237,237,0.4);text-align:center;">
        {{ total_listings }} listings tracked ·
        <a href="{{ dashboard_url }}" style="color:rgba(237,237,237,0.6);">dashboard</a>
      </p>
      <p style="margin:8px 0 0 0;font-size:11px;color:rgba(237,237,237,0.3);text-align:center;">
        © {{ year }} Visual Entropy Productions
      </p>
    </div>
  </body>
</html>
